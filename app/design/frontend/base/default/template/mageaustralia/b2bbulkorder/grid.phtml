.b2b-bulk-order__tax-toggle { display: inline-flex; border: 1px solid #d1d5db; border-radius: 6px; overflow: hidden; }
.b2b-tax-btn { background: #fff; border: none; padding: 8px 14px; font-size: 13px; font-weight: 600; cursor: pointer; color: #374151; }
.b2b-tax-btn + .b2b-tax-btn { border-left: 1px solid #d1d5db; }
.b2b-tax-btn.is-active { background: #4f46e5; color: #fff; }
.b2b-bulk-order__template-link { font-size: 13px; color: #4f46e5; }

.b2b-bulk-order__count { font-size: 13px; color: #6b7280; padding: 6px 0 12px; }

.b2b-bulk-order__unmatched { background: #fef2f2; border: 1px solid #fecaca; padding: 12px 16px; border-radius: 4px; margin-bottom: 16px; }
.b2b-bulk-order__unmatched h3 { color: #991b1b; margin: 0 0 4px; font-size: 14px; }
.b2b-bulk-order__unmatched ul { margin: 6px 0 0; padding-left: 18px; font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 13px; }

