<script>
(function () {
  'use strict';
  const CFG = <?= Mage::helper('core')->jsonEncode([
    'parseUrl'   => $this->getParseUrl(),
    'uploadUrl'  => $this->getUploadUrl(),
    'taxUrl'     => $this->getSetTaxDisplayUrl(),
    'taxMode'    => $taxMode,
    'formKey'    => Mage::getSingleton('core/session')->getFormKey(),
    'currencyCode' => Mage::app()->getStore()->getCurrentCurrencyCode(),
  ]) ?>;
  let taxMode = CFG.taxMode | 0;
  const rows = new Map(); // sku -> {sku, name, qty, unitPriceInc, unitPriceEx, url, productId}

  const $body = document.getElementById('b2b-bulk-grid-body');
  const $unmatched = document.getElementById('b2b-bulk-unmatched');
  const $unmatchedList = document.getElementById('b2b-bulk-unmatched-list');
  const $addToCart = document.getElementById('b2b-bulk-add-to-cart');
  const $sendQuote = document.getElementById('b2b-bulk-send-quote');
  const $total = document.getElementById('b2b-bulk-total');

  function money(n) {
    try {
      return new Intl.NumberFormat(undefined, { style: 'currency', currency: CFG.currencyCode }).format(n);
    } catch (e) {
      return (Math.round(n * 100) / 100).toFixed(2);
    }
  }
  function unitPrice(row) { return taxMode === 1 ? row.unitPriceInc : row.unitPriceEx; }
  function refreshLabels() {
    document.querySelectorAll('[data-role="tax-label"]').forEach(el => {
      const isTotal = el.tagName.toLowerCase() === 'strong';
      el.textContent = isTotal
        ? (taxMode === 1 ? 'Total inc tax' : 'Total ex tax')
        : (taxMode === 1 ? 'Price inc tax' : 'Price ex tax');
    });
  }
  function render() {
    if (rows.size === 0) {
      $body.innerHTML = '<tr class="b2b-bulk-empty"><td colspan="6">Paste SKUs above or upload a CSV to populate the grid.</td></tr>';
      $addToCart.disabled = true;
      if ($sendQuote) $sendQuote.disabled = true;
      $total.textContent = '-';
      return;
    }
    let total = 0;
    const trs = [];
    for (const [sku, row] of rows) {
      const line = unitPrice(row) * row.qty;
      total += line;
      trs.push(
        '<tr data-sku="' + escapeAttr(sku) + '">'
        + '<td class="col-sku"><a href="' + escapeAttr(row.url) + '" target="_blank" rel="noopener">' + escapeHtml(sku) + '</a></td>'
        + '<td class="col-name">' + escapeHtml(row.name) + '</td>'
        + '<td class="col-price">' + money(unitPrice(row)) + '</td>'
        + '<td class="col-qty">'
        +   '<input type="number" min="1" step="1" value="' + row.qty + '" data-role="qty" aria-label="Quantity for ' + escapeAttr(sku) + '">'
        +   '<input type="hidden" name="sku[]" value="' + escapeAttr(sku) + '">'
        +   '<input type="hidden" name="qty[]" value="' + row.qty + '" data-role="qty-hidden">'
        + '</td>'
        + '<td class="col-line">' + money(line) + '</td>'
        + '<td class="col-x"><button type="button" data-role="remove" aria-label="Remove ' + escapeAttr(sku) + '">&times;</button></td>'
        + '</tr>'
      );
    }
    $body.innerHTML = trs.join('');
    $total.textContent = money(total);
    $addToCart.disabled = false;
    if ($sendQuote) $sendQuote.disabled = false;
  }
  function escapeHtml(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }
  function escapeAttr(s) { return escapeHtml(s); }

  function mergeMatched(matched) {
    for (const row of matched) {
      const key = row.sku;
      if (rows.has(key)) {
        const cur = rows.get(key);
        cur.qty += row.qty;
      } else {
        rows.set(key, row);
      }
    }
  }
  function showUnmatched(list) {
    if (!list || !list.length) {
      $unmatched.hidden = true;
      $unmatchedList.innerHTML = '';
      return;
    }
    $unmatched.hidden = false;
    $unmatchedList.innerHTML = list.map(s => '<li>' + escapeHtml(s) + '</li>').join('');
  }

  async function post(url, body, isFormData) {
    const res = await fetch(url, {
      method: 'POST',
      body: isFormData ? body : new URLSearchParams(body),
      credentials: 'same-origin',
    });
    if (!res.ok) throw new Error('http ' + res.status);
    return res.json();
  }

  document.getElementById('b2b-bulk-paste-add').addEventListener('click', async () => {
    const lines = document.getElementById('b2b-bulk-paste').value;
    if (!lines.trim()) return;
    try {
      const data = await post(CFG.parseUrl, { form_key: CFG.formKey, lines });
      mergeMatched(data.matched);
      showUnmatched(data.unmatched);
      render();
      document.getElementById('b2b-bulk-paste').value = '';
    } catch (e) {
      alert('Lookup failed: ' + e.message);
    }
  });

  document.getElementById('b2b-bulk-upload-form').addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const form = ev.target;
    const fd = new FormData(form);
    try {
      const data = await post(CFG.uploadUrl, fd, true);
      mergeMatched(data.matched);
      showUnmatched(data.unmatched);
      render();
      form.reset();
    } catch (e) {
      alert('Upload failed: ' + e.message);
    }
  });

  document.querySelectorAll('[data-action="b2b-bulk-order-tax"]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const mode = btn.getAttribute('data-mode') | 0;
      try {
        await post(CFG.taxUrl, { form_key: CFG.formKey, mode: String(mode) });
      } catch (e) { /* non-fatal - session update is a nicety, UI switch below is what matters */ }
      taxMode = mode;
      document.querySelectorAll('.b2b-tax-btn').forEach(b => b.classList.toggle('is-active', (b.getAttribute('data-mode') | 0) === mode));
      refreshLabels();
      render();
    });
  });

  $body.addEventListener('input', (ev) => {
    if (ev.target.matches('[data-role="qty"]')) {
      const tr = ev.target.closest('tr');
      const sku = tr.getAttribute('data-sku');
      const row = rows.get(sku);
      if (!row) return;
      const q = Math.max(1, parseInt(ev.target.value, 10) || 1);
      row.qty = q;
      tr.querySelector('[data-role="qty-hidden"]').value = q;
      tr.querySelector('.col-line').textContent = money(unitPrice(row) * q);
      let total = 0;
      rows.forEach(r => { total += unitPrice(r) * r.qty; });
      $total.textContent = money(total);
    }
  });
  $body.addEventListener('click', (ev) => {
    if (ev.target.matches('[data-role="remove"]')) {
      const tr = ev.target.closest('tr');
      const sku = tr.getAttribute('data-sku');
      rows.delete(sku);
      render();
    }
  });
})();
</script>
