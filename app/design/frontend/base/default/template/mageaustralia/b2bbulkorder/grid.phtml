.b2b-bulk-order__pager a { color: #4f46e5; text-decoration: none; }

.b2b-bulk-order__actions { display: flex; gap: 12px; margin-top: 16px; padding-top: 12px; border-top: 1px solid #e5e7eb; justify-content: flex-end; align-items: center; flex-wrap: wrap; }
.b2b-bulk-order__save-as-req { display: inline-flex; gap: 6px; align-items: center; margin-right: auto; }
.b2b-bulk-order__save-as-req input { padding: 8px 12px; border: 1px solid #d1d5db; border-radius: 4px; font-size: 13px; min-width: 220px; }
.button-outline { background: #eef2ff; color: #4f46e5; border: 1px solid #c7d2fe; padding: 8px 14px; font-weight: 600; border-radius: 4px; cursor: pointer; }
.button-outline:hover:not(:disabled) { background: #4f46e5; color: #fff; }
.button-primary { background: #4f46e5; color: #fff; }
.button-primary:disabled, .button:disabled { opacity: 0.55; cursor: not-allowed; }

.b2b-bulk-order__paste-advanced { margin-top: 32px; border-top: 1px solid #e5e7eb; padding-top: 16px; }
.b2b-bulk-order__paste-advanced summary { font-weight: 600; color: #4f46e5; cursor: pointer; padding: 6px 0; }
.b2b-bulk-order__paste-advanced summary:hover { text-decoration: underline; }
.b2b-bulk-order__inputs { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 16px; }
@media (max-width: 720px) { .b2b-bulk-order__inputs { grid-template-columns: 1fr; } }
.b2b-bulk-order__input-block h2 { font-size: 15px; margin: 0 0 6px; }
.b2b-bulk-order__input-block .hint { font-size: 12px; color: #6b7280; margin: 0 0 8px; }
.b2b-bulk-order__input-block textarea { width: 100%; box-sizing: border-box; padding: 8px 10px; border: 1px solid #d1d5db; border-radius: 4px; font-family: ui-monospace, "SF Mono", Menlo, monospace; }
.b2b-bulk-order__input-block button { margin-top: 8px; }
</style>

<script>
(function () {
  'use strict';
  const CFG = <?= Mage::helper('core')->jsonEncode([
    'parseUrl'   => $this->getParseUrl(),
    'uploadUrl'  => $this->getUploadUrl(),
    'taxUrl'     => $this->getSetTaxDisplayUrl(),
    'optionsUrl' => $this->getOptionsUrl(),
    'taxMode'    => $taxMode,
    'formKey'    => Mage::getSingleton('core/session')->getFormKey(),
    'currencyCode' => Mage::app()->getStore()->getCurrentCurrencyCode(),
  ]) ?>;
  let taxMode = CFG.taxMode | 0;

  const $body = document.getElementById('b2b-bulk-grid-body');
  const $unmatched = document.getElementById('b2b-bulk-unmatched');
  const $unmatchedList = document.getElementById('b2b-bulk-unmatched-list');
  const $addToCart = document.getElementById('b2b-bulk-add-to-cart');
  const $submitPo = document.getElementById('b2b-bulk-submit-po');
  const $sendQuote = document.getElementById('b2b-bulk-send-quote');
  const $saveReq = document.getElementById('b2b-bulk-save-req');
  const $total = document.getElementById('b2b-bulk-total');

  function money(n) {
    try { return new Intl.NumberFormat(undefined, { style: 'currency', currency: CFG.currencyCode }).format(n); }
    catch (e) { return (Math.round(n * 100) / 100).toFixed(2); }
  }
  function unitOf(tr) { return taxMode === 1 ? parseFloat(tr.dataset.priceInc || '0') : parseFloat(tr.dataset.priceEx || '0'); }
  function qtyOf(tr) { const i = tr.querySelector('[data-role="qty"]'); return i ? Math.max(0, parseInt(i.value, 10) || 0) : 0; }
  function updateRow(tr) {
    const qty = qtyOf(tr);
    const unit = unitOf(tr);
    const line = qty * unit;
    tr.classList.toggle('has-qty', qty > 0);
    tr.querySelector('[data-role="line-total"]').textContent = qty > 0 ? money(line) : '-';
    return line;
  }
  function refreshTotals() {
    let total = 0;
    let anyQty = false;
    document.querySelectorAll('#b2b-bulk-grid tbody tr[data-sku]').forEach(tr => {
      const line = updateRow(tr);
      total += line;
      if (line > 0) anyQty = true;
    });
    $total.textContent = anyQty ? money(total) : '-';
    if ($addToCart) $addToCart.disabled = !anyQty;
    if ($submitPo) $submitPo.disabled = !anyQty;
    if ($sendQuote) $sendQuote.disabled = !anyQty;
    if ($saveReq) $saveReq.disabled = !anyQty;
  }
  function refreshLabels() {
    document.querySelectorAll('[data-role="tax-label"]').forEach(el => {
      const isTotal = el.tagName.toLowerCase() === 'strong';
      el.textContent = isTotal
        ? (taxMode === 1 ? 'Total inc tax' : 'Total ex tax')
        : (taxMode === 1 ? 'Price inc tax' : 'Price ex tax');
    });
    // Also update visible per-row unit price
    document.querySelectorAll('#b2b-bulk-grid tbody tr[data-sku]').forEach(tr => {
      tr.querySelector('[data-role="unit-price"]').textContent = money(unitOf(tr));
    });
  }

  $body.addEventListener('input', (ev) => {
    if (ev.target.matches('[data-role="qty"]')) {
      const tr = ev.target.closest('tr');
      refreshTotals();
      // slight optimisation: only recompute this row's line + running total below
      tr.querySelector('[data-role="line-total"]').textContent = qtyOf(tr) > 0 ? money(qtyOf(tr) * unitOf(tr)) : '-';
    }
  });

  document.querySelectorAll('[data-action="b2b-bulk-order-tax"]').forEach(btn => {
    btn.addEventListener('click', async (ev) => {
      ev.preventDefault();
      const mode = btn.getAttribute('data-mode') | 0;
      try {
        await fetch(CFG.taxUrl, {
          method: 'POST',
          body: new URLSearchParams({ form_key: CFG.formKey, mode: String(mode) }),
          credentials: 'same-origin',
        });
      } catch (e) { /* non-fatal */ }
      taxMode = mode;
      document.querySelectorAll('.b2b-tax-btn').forEach(b => b.classList.toggle('is-active', (b.getAttribute('data-mode') | 0) === mode));
      refreshLabels();
      refreshTotals();
    });
  });

  async function postJson(url, body, isFormData) {
    const res = await fetch(url, {
      method: 'POST',
      body: isFormData ? body : new URLSearchParams(body),
      credentials: 'same-origin',
    });
    if (!res.ok) throw new Error('http ' + res.status);
    return res.json();
  }

  function applyToGrid(matched, unmatched) {
    for (const m of matched) {
      const tr = document.querySelector('#b2b-bulk-grid tbody tr[data-sku="' + CSS.escape(m.sku) + '"]');
      if (tr) {
        const inp = tr.querySelector('[data-role="qty"]');
        const curr = parseInt(inp.value, 10) || 0;
        inp.value = String(curr + m.qty);
      } else {
        // SKU exists in catalogue but isn't on the current page (search filter etc).
        // Show it as an "off-page" row so the buyer knows their paste was accepted.
        // Simpler: add to unmatched list with a note.
        unmatched.push(m.sku + ' (on another page)');
      }
    }
    if (unmatched.length) {
      $unmatched.hidden = false;
      $unmatchedList.innerHTML = unmatched.map(s => '<li>' + s.replace(/[<>&]/g, '') + '</li>').join('');
    } else {
      $unmatched.hidden = true;
      $unmatchedList.innerHTML = '';
    }
    refreshTotals();
  }

  document.getElementById('b2b-bulk-paste-add').addEventListener('click', async () => {
    const lines = document.getElementById('b2b-bulk-paste').value;
    if (!lines.trim()) return;
    try {
      const data = await postJson(CFG.parseUrl, { form_key: CFG.formKey, lines });
      applyToGrid(data.matched, data.unmatched.slice());
      document.getElementById('b2b-bulk-paste').value = '';
    } catch (e) { alert('Lookup failed: ' + e.message); }
  });

  document.getElementById('b2b-bulk-upload-form').addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const form = ev.target;
    try {
      const data = await postJson(CFG.uploadUrl, new FormData(form), true);
      applyToGrid(data.matched, data.unmatched.slice());
      form.reset();
    } catch (e) { alert('Upload failed: ' + e.message); }
  });

  refreshTotals();

  /* ─── Options modal ─────────────────────────────────────────────
     Concept borrowed from the POS terminal's configurable-product modal:
     fetch parent → dropdowns per attribute → resolve chosen combination
     to a variant → insert as a new row in the grid.                    */
  const $modal      = document.getElementById('b2b-opt-modal');
  const $modalImg   = document.getElementById('b2b-opt-img');
  const $modalName  = document.getElementById('b2b-opt-parent-name');
  const $modalFields= document.getElementById('b2b-opt-fields');
  const $modalSel   = document.getElementById('b2b-opt-selected');
  const $modalQtyRow= document.getElementById('b2b-opt-qty-row');
  const $modalQty   = document.getElementById('b2b-opt-qty');
  const $modalError = document.getElementById('b2b-opt-error');
  const $modalAdd   = document.getElementById('b2b-opt-add');

  let modalState = null; // { parentSku, name, options: [...], variants: [...], selection: {code:valueId}, currentVariant }

  function openModal() { $modal.hidden = false; document.body.style.overflow = 'hidden'; }
  function closeModal() {
    $modal.hidden = true;
    document.body.style.overflow = '';
    modalState = null;
    $modalFields.innerHTML = '';
    $modalSel.hidden = true;
    $modalQtyRow.hidden = true;
    $modalError.hidden = true;
    $modalAdd.disabled = true;
    if ($modalImg) { $modalImg.hidden = true; $modalImg.src = ''; }
  }
  function showError(msg) { $modalError.textContent = msg; $modalError.hidden = false; }

  function renderFields() {
    $modalFields.innerHTML = '';
    for (const opt of modalState.options) {
      const wrap = document.createElement('div');
      const lbl = document.createElement('label');
      lbl.textContent = opt.label || opt.code;
      lbl.setAttribute('for', 'b2b-opt-' + opt.code);
      const sel = document.createElement('select');
      sel.id = 'b2b-opt-' + opt.code;
      sel.dataset.optionCode = opt.code;
      const placeholder = document.createElement('option');
      placeholder.value = '';
      placeholder.textContent = '-- ' + (opt.label || opt.code) + ' --';
      sel.appendChild(placeholder);
      for (const v of opt.values) {
        const o = document.createElement('option');
        o.value = String(v.id);
        o.textContent = v.label;
        sel.appendChild(o);
      }
      sel.addEventListener('change', onSelectionChange);
      wrap.appendChild(lbl);
      wrap.appendChild(sel);
      $modalFields.appendChild(wrap);
    }
  }

  function onSelectionChange() {
    const selection = {};
    $modalFields.querySelectorAll('select').forEach(s => {
      if (s.value !== '') selection[s.dataset.optionCode] = parseInt(s.value, 10);
    });
    modalState.selection = selection;
    const complete = modalState.options.every(o => selection[o.code] !== undefined);
    if (!complete) {
      $modalSel.hidden = true;
      $modalQtyRow.hidden = true;
      $modalAdd.disabled = true;
      modalState.currentVariant = null;
      return;
    }
    // Find matching variant
    const match = modalState.variants.find(v => {
      for (const [code, id] of Object.entries(selection)) {
        if ((v.attributes[code] | 0) !== (id | 0)) return false;
      }
      return true;
    });
    modalState.currentVariant = match || null;
    if (!match) {
      showError('That combination isn\'t available.');
      $modalSel.hidden = true;
      $modalQtyRow.hidden = true;
      $modalAdd.disabled = true;
      return;
    }
    $modalError.hidden = true;
    $modalSel.querySelector('[data-role="sku"]').textContent = match.sku;
    const priceLabel = taxMode === 1 ? 'Price inc tax:' : 'Price ex tax:';
    const unit = taxMode === 1 ? match.priceInc : match.priceEx;
    $modalSel.querySelector('[data-role="tax-label"]').textContent = priceLabel;
    $modalSel.querySelector('[data-role="price"]').textContent = money(unit);
    const stockEl = $modalSel.querySelector('[data-role="stock-line"]');
    stockEl.innerHTML = match.inStock
      ? '<span class="in-stock">In stock</span>'
      : '<span class="out-of-stock">Out of stock</span>';
    $modalSel.hidden = false;
    $modalQtyRow.hidden = !match.inStock;
    $modalAdd.disabled = !match.inStock;
  }

  async function openForButton(btn) {
    const productId = btn.dataset.productId;
    const parentName = btn.dataset.name || btn.dataset.sku;
    modalState = { parentSku: btn.dataset.sku, name: parentName, options: [], variants: [], selection: {}, currentVariant: null };
    $modalName.textContent = parentName;
    $modalFields.innerHTML = '<div style="color:#6b7280;font-size:13px;padding:8px 0;">Loading options...</div>';
    openModal();
    try {
      const res = await fetch(CFG.optionsUrl + '?product_id=' + encodeURIComponent(productId), {
        credentials: 'same-origin',
        headers: { Accept: 'application/json' },
      });
      if (!res.ok) throw new Error('http ' + res.status);
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      modalState.options = data.options || [];
      modalState.variants = data.variants || [];
      if (data.imageUrl) { $modalImg.src = data.imageUrl; $modalImg.hidden = false; }
      $modalName.textContent = data.name || parentName;
      if (!modalState.options.length) {
        $modalFields.innerHTML = '<div style="color:#6b7280;font-size:13px;">This product has no selectable options.</div>';
        return;
      }
      renderFields();
    } catch (e) {
      $modalFields.innerHTML = '';
      showError('Couldn\'t load options: ' + e.message);
    }
  }

  function addVariantAsRow() {
    if (!modalState || !modalState.currentVariant) return;
    const v = modalState.currentVariant;
    const qty = Math.max(1, parseInt($modalQty.value, 10) || 1);

    // If a row for that SKU already exists (buyer picked it before), just
    // bump the qty on that row instead of adding a duplicate.
    const existing = $body.querySelector('tr[data-sku="' + CSS.escape(v.sku) + '"]');
    if (existing) {
      const qtyInp = existing.querySelector('[data-role="qty"]');
      if (qtyInp) qtyInp.value = String((parseInt(qtyInp.value, 10) || 0) + qty);
      refreshTotals();
      existing.scrollIntoView({ behavior: 'smooth', block: 'center' });
      closeModal();
      return;
    }

    // Otherwise: build a new row and insert it directly below the parent
    // (which is the currently-open one - but the button doesn't know its
    //  own row directly, so we insert at the top of the grid so the buyer
    //  can see the variant land).
    const tr = document.createElement('tr');
    tr.dataset.sku = v.sku;
    tr.dataset.priceEx = String(v.priceEx);
    tr.dataset.priceInc = String(v.priceInc);
    tr.dataset.type = 'simple';
    tr.dataset.addedByOptions = '1';
    tr.classList.add('has-qty');

    const priceCell = money(taxMode === 1 ? v.priceInc : v.priceEx);
    tr.innerHTML = `
      <td class="col-img"></td>
      <td class="col-sku">${v.sku.replace(/[<>&]/g, '')}<span class="type-badge">variant</span></td>
      <td class="col-name">${(v.name || modalState.name).replace(/[<>&]/g, '')}</td>
      <td class="col-stock"><span class="stock-badge in">In stock</span></td>
      <td class="col-price" data-role="unit-price">${priceCell}</td>
      <td class="col-qty">
        <input type="number" min="0" step="1" value="${qty}" data-role="qty" name="qty[${v.sku.replace(/"/g,'&quot;')}]">
      </td>
      <td class="col-line" data-role="line-total">${money(qty * (taxMode === 1 ? v.priceInc : v.priceEx))}</td>
    `;

    // Insert at the top so it's visible immediately
    $body.insertBefore(tr, $body.firstElementChild);
    refreshTotals();
    tr.scrollIntoView({ behavior: 'smooth', block: 'center' });
    closeModal();
  }

  document.addEventListener('click', (ev) => {
    const btn = ev.target.closest('[data-action="b2b-choose-options"]');
    if (btn) {
      ev.preventDefault();
      openForButton(btn);
      return;
    }
    if (ev.target.closest('[data-action="b2b-opt-close"]')) {
      ev.preventDefault();
      closeModal();
      return;
    }
  });
  $modalAdd.addEventListener('click', addVariantAsRow);
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape' && !$modal.hidden) closeModal();
  });
})();
</script>
