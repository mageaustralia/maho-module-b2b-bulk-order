$helper = $this->b2bHelper();
$taxMode = $helper->getTaxDisplayMode();
$rfqOk   = $this->isRfqAvailable();
$reqOk   = $this->isRequisitionAvailable();
$poOk    = $this->isSubmitForApprovalAvailable();
$products = $this->getProductCollection();
$search = $this->getSearchTerm();
$catId = $this->getCurrentCategoryId();
$currentPage = $this->getCurrentPage();
$pageCount = $this->getPageCount();
$total = (int) $products->getSize();
$catOptions = $this->getCategoryOptions();
?>
<div class="b2b-bulk-order">
    <div class="page-title">
        <h1><?= $this->escapeHtml($this->__('Bulk order')) ?></h1>
    </div>

    <p class="b2b-bulk-order__lede">
        <?= $this->escapeHtml($this->__(
            'Browse the catalogue, set a quantity on any line you want, and choose whether to check out '
            . 'immediately or send the whole list as a quote request. Use the search + category filters to '
            . 'narrow down, or paste a list of SKUs at the bottom if you already know what you need.',
        )) ?>
    </p>

    <form method="get" action="<?= $this->escapeUrl($this->getUrl('bulk-order')) ?>" class="b2b-bulk-order__filter">
        <input type="search" name="q" value="<?= $this->escapeHtml($search) ?>" placeholder="<?= $this->escapeHtml($this->__('Search by SKU or name')) ?>">
        <?php if ($catOptions): ?>
        <select name="cat" aria-label="<?= $this->escapeHtml($this->__('Filter by category')) ?>">
            <option value=""><?= $this->escapeHtml($this->__('All categories')) ?></option>
            <?php foreach ($catOptions as $id => $name): ?>
                <option value="<?= (int) $id ?>" <?= $catId === (int) $id ? 'selected' : '' ?>><?= $this->escapeHtml($name) ?></option>
            <?php endforeach; ?>
        </select>
        <?php endif; ?>
        <button type="submit" class="button"><?= $this->escapeHtml($this->__('Search')) ?></button>
        <?php if ($search !== '' || $catId > 0): ?>
            <a class="b2b-bulk-order__clear" href="<?= $this->escapeUrl($this->getUrl('bulk-order')) ?>"><?= $this->escapeHtml($this->__('Clear')) ?></a>
        <?php endif; ?>
        <div class="b2b-bulk-order__toolbar">
            <div class="b2b-bulk-order__tax-toggle" role="radiogroup" aria-label="Price display mode">
                <button type="button" class="b2b-tax-btn <?= $taxMode === 0 ? 'is-active' : '' ?>"
                        data-mode="0" data-action="b2b-bulk-order-tax">
                    <?= $this->escapeHtml($this->__('Ex tax')) ?>
                </button>
                <button type="button" class="b2b-tax-btn <?= $taxMode === 1 ? 'is-active' : '' ?>"
                        data-mode="1" data-action="b2b-bulk-order-tax">
                    <?= $this->escapeHtml($this->__('Inc tax')) ?>
                </button>
            </div>
            <a class="b2b-bulk-order__template-link" href="<?= $this->escapeUrl($this->getTemplateUrl()) ?>">
                <?= $this->escapeHtml($this->__('Download CSV template')) ?>
            </a>
        </div>
    </form>

    <div id="b2b-bulk-unmatched" class="b2b-bulk-order__unmatched" hidden>
        <h3><?= $this->escapeHtml($this->__('Not found on this store')) ?></h3>
        <p class="hint"><?= $this->escapeHtml($this->__('These SKUs are unknown - matched rows above have been updated.')) ?></p>
        <ul id="b2b-bulk-unmatched-list"></ul>
    </div>

    <form id="b2b-bulk-cart-form" method="post" class="b2b-bulk-order__cart">
        <input type="hidden" name="form_key" value="<?= $this->escapeHtml(Mage::getSingleton('core/session')->getFormKey()) ?>">

        <div class="b2b-bulk-order__count">
            <?= $this->escapeHtml($this->__('%d products', $total)) ?>
            <?php if ($search !== ''): ?> · <?= $this->escapeHtml($this->__('matching "%s"', $search)) ?><?php endif; ?>
            <?php if ($catId > 0 && isset($catOptions[$catId])): ?> · <?= $this->escapeHtml($catOptions[$catId]) ?><?php endif; ?>
        </div>

        <table class="b2b-bulk-order__grid" id="b2b-bulk-grid">
            <thead>
                <tr>
                    <th class="col-img" aria-label="image"></th>
                    <th class="col-sku"><?= $this->escapeHtml($this->__('SKU')) ?></th>
                    <th class="col-name"><?= $this->escapeHtml($this->__('Name')) ?></th>
                    <th class="col-stock"><?= $this->escapeHtml($this->__('Stock')) ?></th>
                    <th class="col-price">
                        <span data-role="tax-label"><?= $this->escapeHtml($taxMode === 1 ? $this->__('Price inc tax') : $this->__('Price ex tax')) ?></span>
                    </th>
                    <th class="col-qty"><?= $this->escapeHtml($this->__('Qty')) ?></th>
                    <th class="col-line"><?= $this->escapeHtml($this->__('Line total')) ?></th>
                </tr>
            </thead>
            <tbody id="b2b-bulk-grid-body">
                <?php if ($total === 0): ?>
                    <tr><td colspan="7" class="b2b-bulk-empty">
                        <?= $this->escapeHtml($this->__('No products match the current filter. Try a different search or clear the filter.')) ?>
                    </td></tr>
                <?php endif; ?>
                <?php foreach ($products as $product): ?>
                    <?php
                    /** @var Mage_Catalog_Model_Product $product */
                    $sku = (string) $product->getSku();
                    $prices = $helper->getUnitPrices($product);
                    $inc = $prices['inc'];
                    $exc = $prices['ex'];
                    $unit = $taxMode === 1 ? $inc : $exc;
                    $inStock = (bool) Mage::getModel('cataloginventory/stock_item')->loadByProduct($product)->getIsInStock();
                    $imgUrl = (string) $product->getSmallImage();
                    if ($imgUrl && $imgUrl !== 'no_selection') {
                        $imgUrl = Mage::getSingleton('catalog/product_media_config')->getMediaUrl($imgUrl);
                    } else {
                        $imgUrl = '';
                    }
                    $typeId = (string) $product->getTypeId();
                    // Configurable/bundle/grouped products need the buyer to
                    // pick options (size / colour / bundle sub-items). Direct-
                    // add-to-cart of a configurable parent by SKU produces an
                    // "options required" error - so send the buyer to the PDP
                    // with a return-to instead of showing a qty input.
                    $needsOptions = in_array($typeId, ['configurable', 'bundle', 'grouped'], true)
                        || $product->getHasOptions();
                    ?>
                    <tr data-sku="<?= $this->escapeHtml($sku) ?>"
                        data-product-id="<?= (int) $product->getId() ?>"
                        data-price-inc="<?= $this->escapeHtml((string) $inc) ?>"
                        data-price-ex="<?= $this->escapeHtml((string) $exc) ?>"
                        data-type="<?= $this->escapeHtml($typeId) ?>">
                        <td class="col-img">
                            <?php if ($imgUrl): ?>
                                <img src="<?= $this->escapeUrl($imgUrl) ?>" alt="" loading="lazy">
                            <?php endif; ?>
                        </td>
                        <td class="col-sku">
                            <a href="<?= $this->escapeUrl($product->getProductUrl()) ?>" target="_blank" rel="noopener"><?= $this->escapeHtml($sku) ?></a>
                            <?php if ($needsOptions): ?>
                                <span class="type-badge"><?= $this->escapeHtml($this->__('has options')) ?></span>
                            <?php endif; ?>
                        </td>
                        <td class="col-name"><?= $this->escapeHtml((string) $product->getName()) ?></td>
                        <td class="col-stock">
                            <span class="stock-badge <?= $inStock ? 'in' : 'out' ?>"><?= $this->escapeHtml($inStock ? $this->__('In stock') : $this->__('Out of stock')) ?></span>
                        </td>
                        <td class="col-price" data-role="unit-price">
                            <?php if ($needsOptions): ?>
                                <?= $this->escapeHtml($this->__('From')) ?> <?= $this->escapeHtml(Mage::helper('core')->currency($unit, true, false)) ?>
                            <?php else: ?>
                                <?= $this->escapeHtml(Mage::helper('core')->currency($unit, true, false)) ?>
                            <?php endif; ?>
                        </td>
                        <td class="col-qty">
                            <?php if ($needsOptions): ?>
                                <button type="button" class="button button-small"
                                        data-action="b2b-choose-options"
                                        data-product-id="<?= (int) $product->getId() ?>"
                                        data-sku="<?= $this->escapeHtml($sku) ?>"
                                        data-name="<?= $this->escapeHtml((string) $product->getName()) ?>"
                                        title="<?= $this->escapeHtml($this->__('Pick a variant + qty inline. The chosen variant appears as its own row below.')) ?>">
                                    <?= $this->escapeHtml($this->__('Choose options →')) ?>
                                </button>
                            <?php else: ?>
                                <input type="number" min="0" step="1" value="0" data-role="qty" name="qty[<?= $this->escapeHtml($sku) ?>]" aria-label="Quantity for <?= $this->escapeHtml($sku) ?>" <?= $inStock ? '' : 'disabled' ?>>
                            <?php endif; ?>
                        </td>
                        <td class="col-line" data-role="line-total">&mdash;</td>
                    </tr>
                <?php endforeach; ?>
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="6" style="text-align:right;">
                        <strong data-role="tax-label"><?= $this->escapeHtml($taxMode === 1 ? $this->__('Total inc tax') : $this->__('Total ex tax')) ?></strong>
                    </td>
                    <td class="col-line" id="b2b-bulk-total">&mdash;</td>
                </tr>
            </tfoot>
        </table>

        <?php if ($pageCount > 1): ?>
        <nav class="b2b-bulk-order__pager" aria-label="Pagination">
            <?php if ($currentPage > 1): ?>
                <a href="<?= $this->escapeUrl($this->getPageUrl($currentPage - 1)) ?>"><?= $this->escapeHtml($this->__('« Prev')) ?></a>
            <?php endif; ?>
            <span><?= $this->escapeHtml($this->__('Page %d of %d', $currentPage, $pageCount)) ?></span>
            <?php if ($currentPage < $pageCount): ?>
                <a href="<?= $this->escapeUrl($this->getPageUrl($currentPage + 1)) ?>"><?= $this->escapeHtml($this->__('Next »')) ?></a>
            <?php endif; ?>
        </nav>
        <?php endif; ?>

        <div class="b2b-bulk-order__actions">
            <?php if ($reqOk): ?>
                <div class="b2b-bulk-order__save-as-req">
                    <input type="text" name="name" maxlength="128"
                           placeholder="<?= $this->escapeHtml($this->__('List name (optional)')) ?>"
                           id="b2b-bulk-req-name">
                    <button type="submit" formaction="<?= $this->escapeUrl((string) $this->getSaveAsRequisitionUrl()) ?>"
                            class="button button-outline" id="b2b-bulk-save-req" disabled
                            title="<?= $this->escapeHtml($this->__('Save this bulk cart as a requisition list you can reorder later.')) ?>">
                        <?= $this->escapeHtml($this->__('Save as list')) ?>
                    </button>
                </div>
            <?php endif; ?>
            <?php if ($poOk): ?>
                <button type="submit" formaction="<?= $this->escapeUrl((string) $this->getSubmitForApprovalUrl()) ?>"
                        class="button button-primary" id="b2b-bulk-submit-po" disabled
                        title="<?= $this->escapeHtml($this->__("Submit for your company admin's approval instead of ordering directly.")) ?>">
                    <?= $this->escapeHtml($this->__('Submit for approval')) ?>
                </button>
            <?php else: ?>
                <button type="submit" formaction="<?= $this->escapeUrl($this->getAddToCartUrl()) ?>"
                        class="button button-primary" id="b2b-bulk-add-to-cart" disabled>
                    <?= $this->escapeHtml($this->__('Buy Now - add selected to cart')) ?>
                </button>
            <?php endif; ?>
            <?php if ($rfqOk): ?>
                <button type="submit" formaction="<?= $this->escapeUrl((string) $this->getSendAsQuoteUrl()) ?>"
                        class="button" id="b2b-bulk-send-quote" disabled>
                    <?= $this->escapeHtml($this->__('Send as Quote request')) ?>
                </button>
            <?php endif; ?>
        </div>
    </form>

    <!-- ────────── Options modal (configurable-product picker) ──────────
         Reuses the concept from POS' configurable-product modal: fetch
         attributes + variants, one dropdown per attribute, resolve the
         chosen combination to a specific child SKU, then insert that SKU
         as a new row in the grid so the buyer can set a qty and submit
         through the same code path as simple products. -->
    <div id="b2b-opt-modal" class="b2b-modal" role="dialog" aria-modal="true" aria-labelledby="b2b-opt-modal-title" hidden>
        <div class="b2b-modal__backdrop" data-action="b2b-opt-close"></div>
        <div class="b2b-modal__panel" role="document">
            <button type="button" class="b2b-modal__close" data-action="b2b-opt-close" aria-label="Close">&times;</button>
            <div class="b2b-modal__header">
                <div class="b2b-modal__thumb"><img id="b2b-opt-img" src="" alt="" hidden></div>
                <div>
                    <h2 id="b2b-opt-modal-title"><?= $this->escapeHtml($this->__('Choose options')) ?></h2>
                    <div id="b2b-opt-parent-name" class="b2b-modal__lede"></div>
                </div>
            </div>
            <div id="b2b-opt-body">
                <div id="b2b-opt-fields"></div>
                <div id="b2b-opt-selected" class="b2b-modal__selected" hidden>
                    <div class="b2b-modal__selected-line"><strong><?= $this->escapeHtml($this->__('SKU')) ?>:</strong> <span data-role="sku"></span></div>
                    <div class="b2b-modal__selected-line"><strong data-role="tax-label"></strong> <span data-role="price"></span></div>
                    <div class="b2b-modal__selected-line" data-role="stock-line"></div>
                </div>
                <div id="b2b-opt-qty-row" hidden>
                    <label for="b2b-opt-qty"><?= $this->escapeHtml($this->__('Qty')) ?></label>
                    <input type="number" id="b2b-opt-qty" min="1" step="1" value="1">
                </div>
                <div id="b2b-opt-error" class="b2b-modal__error" hidden></div>
            </div>
            <div class="b2b-modal__actions">
                <button type="button" class="button" data-action="b2b-opt-close">
                    <?= $this->escapeHtml($this->__('Cancel')) ?>
                </button>
                <button type="button" class="button button-primary" id="b2b-opt-add" disabled>
                    <?= $this->escapeHtml($this->__('Add to grid')) ?>
                </button>
            </div>
        </div>
    </div>

    <details class="b2b-bulk-order__paste-advanced">
        <summary><?= $this->escapeHtml($this->__('Or, paste / upload SKUs')) ?></summary>
        <div class="b2b-bulk-order__inputs">
            <section class="b2b-bulk-order__input-block">
                <h2><?= $this->escapeHtml($this->__('Paste SKUs (one per line)')) ?></h2>
                <p class="hint"><?= $this->escapeHtml($this->__('Formats accepted: "SKU", "SKU,qty", "SKU qty".')) ?></p>
                <textarea id="b2b-bulk-paste" rows="6" placeholder="ABL003, 5&#10;WBK002L, 2&#10;msj000t"></textarea>
                <button type="button" id="b2b-bulk-paste-add" class="button"><?= $this->escapeHtml($this->__('Apply to grid')) ?></button>
            </section>
            <section class="b2b-bulk-order__input-block">
                <h2><?= $this->escapeHtml($this->__('Upload a CSV file')) ?></h2>
                <p class="hint"><?= $this->escapeHtml($this->__('Two columns: SKU, Quantity. Download the template if unsure.')) ?></p>
                <form id="b2b-bulk-upload-form" enctype="multipart/form-data">
                    <input type="hidden" name="form_key" value="<?= $this->escapeHtml(Mage::getSingleton('core/session')->getFormKey()) ?>">
                    <input type="file" name="file" accept=".csv,.txt" required>
                    <button type="submit" class="button"><?= $this->escapeHtml($this->__('Apply to grid')) ?></button>
                </form>
            </section>
        </div>
    </details>
</div>

